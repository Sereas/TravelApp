#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [ "${SKIP_SUPABASE_SCHEMA_CHECK:-0}" = "1" ]; then
  exit 0
fi

python_bin="$repo_root/.venv/bin/python"
if [ ! -x "$python_bin" ]; then
  python_bin="python3"
fi

echo "Running Supabase schema sync check..."
"$python_bin" supabase/check_remote_schema.py
echo "Running schema-dependent file check..."
"$python_bin" supabase/check_schema_dependents.py
