#!/usr/bin/env bash
# Pre-push hook — full validation before code reaches remote.
# Runs unit tests, type checks, lint, schema validation, and smoke E2E.
# Blocks the push if any check fails.
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

pass() { echo -e "${GREEN}✓${RESET} $1"; }
fail() { echo -e "${RED}✗ $1${RESET}"; exit 1; }
header() { echo -e "\n${BOLD}── $1${RESET}"; }

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ── 1. Python lint ────────────────────────────────────────────────────────────
header "Python lint (ruff)"
if command -v ruff &>/dev/null; then
  ruff check . || fail "ruff check failed"
  ruff format --check . || fail "ruff format check failed"
  pass "ruff"
elif [ -f ".venv/bin/ruff" ]; then
  .venv/bin/ruff check . || fail "ruff check failed"
  .venv/bin/ruff format --check . || fail "ruff format check failed"
  pass "ruff"
else
  echo "  ruff not found — skipping Python lint"
fi

# ── 2. Backend tests (pytest) ─────────────────────────────────────────────────
header "Backend tests (pytest)"
if [ -f ".venv/bin/python" ]; then
  .venv/bin/python -m pytest -q || fail "pytest failed"
  pass "pytest"
elif command -v python3 &>/dev/null; then
  python3 -m pytest -q || fail "pytest failed"
  pass "pytest"
else
  echo "  python not found — skipping backend tests"
fi

# ── 3. Frontend checks ────────────────────────────────────────────────────────
if [ -d "frontend" ] && [ -f "frontend/package.json" ]; then
  header "Frontend (typecheck + lint + tests)"
  cd frontend
  npm run typecheck || fail "frontend typecheck failed"
  pass "typecheck"
  npm run lint || fail "frontend lint failed"
  pass "lint"
  npm run test || fail "frontend tests failed"
  pass "tests"
  cd "$REPO_ROOT"
fi

# ── 4. Supabase schema checks ────────────────────────────────────────────────
if [ "${SKIP_SUPABASE_SCHEMA_CHECK:-0}" != "1" ]; then
  header "Supabase schema checks"

  python_bin="$REPO_ROOT/.venv/bin/python"
  if [ ! -x "$python_bin" ]; then
    python_bin="python3"
  fi

  "$python_bin" supabase/check_remote_schema.py || fail "schema sync check failed"
  pass "schema sync"
  "$python_bin" supabase/check_schema_dependents.py || fail "schema dependents check failed"
  pass "schema dependents"
fi

# ── 5. Smoke E2E (critical path only) ────────────────────────────────────────
if [ "${SKIP_E2E:-0}" != "1" ]; then
  header "Smoke E2E (critical-path)"

  BACKEND_OK=0
  FRONTEND_OK=0
  curl -sf http://localhost:8000/health >/dev/null 2>&1 && BACKEND_OK=1
  curl -sf http://localhost:3000 >/dev/null 2>&1 && FRONTEND_OK=1

  if [ "$BACKEND_OK" = "1" ] && [ "$FRONTEND_OK" = "1" ]; then
    cd frontend
    E2E_RUN_TRIGGER=push npx playwright test e2e/specs/smoke/critical-path.spec.ts --retries=1 \
      || fail "smoke E2E failed"
    pass "smoke E2E"
    cd "$REPO_ROOT"
  else
    echo -e "  ${RED}✗ Cannot run smoke E2E — services not running:${RESET}"
    [ "$BACKEND_OK" = "0" ] && echo "    ✗ Backend not reachable at http://localhost:8000/health"
    [ "$FRONTEND_OK" = "0" ] && echo "    ✗ Frontend not reachable at http://localhost:3000"
    echo ""
    echo "    Start the services first:"
    echo "      Backend:  uvicorn backend.app.main:app --reload"
    echo "      Frontend: cd frontend && npm run dev"
    echo ""
    echo "    Then retry the push. Use SKIP_E2E=1 only for non-code changes."
    fail "smoke E2E blocked — start backend + frontend and retry"
  fi
else
  echo -e "\n${BOLD}── Smoke E2E${RESET}"
  echo "  Skipped (SKIP_E2E=1)"
fi

echo -e "\n${GREEN}${BOLD}All checks passed — pushing.${RESET}\n"
