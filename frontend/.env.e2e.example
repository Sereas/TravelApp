# E2E Test Configuration
# Copy this file to .env.e2e and fill in the values.
# .env.e2e is gitignored — never commit real credentials.

# ── Test Account ──────────────────────────────────────────────
# A dedicated Supabase Auth user for E2E tests.
# Create via Supabase dashboard: Authentication > Users > Add User.
# This account should NOT be used for manual dev/testing.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# ── URLs ──────────────────────────────────────────────────────
# Frontend (Next.js dev server)
E2E_BASE_URL=http://localhost:3000

# Backend (FastAPI)
E2E_API_URL=http://localhost:8000

# ── Supabase (same values as your frontend/.env.local) ────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Google APIs (optional — set to enable import/route tests) ─
# If set, E2E tests will make real Google API calls.
# If omitted, Google-dependent tests will be skipped.
# Use the same keys as your backend .env.
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=
