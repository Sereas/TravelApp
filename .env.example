# Backend (API). Copy to .env and fill in. See DEPLOYMENT.md for production.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for pre-push schema drift check (Dashboard → Settings → Database)
SUPABASE_DB_PASSWORD=your-db-password
# Optional: fallback for JWT verification (JWKS from SUPABASE_URL is primary)
# SUPABASE_JWT_SECRET=

# Production: override to add more frontend origin(s), comma-separated (default includes localhost + shtabtravel.vercel.app)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://shtabtravel.vercel.app

# Optional: Google APIs (when set, enables Places / Routes features)
# GOOGLE_PLACES_API_KEY=
# GOOGLE_ROUTES_API_KEY=
