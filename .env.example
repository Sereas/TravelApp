# Backend (API). Copy to .env and fill in. See DEPLOYMENT.md for production.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: fallback for JWT verification (JWKS from SUPABASE_URL is primary)
# SUPABASE_JWT_SECRET=

# Production: set to your frontend origin(s), comma-separated
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional: Google APIs (when set, enables Places / Routes features)
# GOOGLE_PLACES_API_KEY=
# GOOGLE_ROUTES_API_KEY=
